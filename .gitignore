!docx-advanced-patterns/**
!docx-template-filling/
!docx-template-filling/**
!rtl-document-translation/
!rtl-document-translation/**
!ralph-loop/
!ralph-loop/**
!rlm-orchestrator/
!rlm-orchestrator/**
!deep-brainstorming/
!deep-brainstorming/**
!project-retrospective/
!project-retrospective/**
!plugins/
!plugins/**

# Web desktop exports
!web-desktop-exports/
!web-desktop-exports/**
